# EditorConfig: https://editorconfig.org
# Formatted with: dotnet format (ships with .NET SDK 6+)

root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

[*.{cs,csx,vb,vbx}]
indent_size = 4
indent_style = space
tab_width = 4

[*.{json,yml,yaml}]
indent_size = 2
indent_style = space

[*.md]
trim_trailing_whitespace = false
